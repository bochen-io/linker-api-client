{
  "name": "bochen-io/linker-api-client",
  "description": "Linker Cloud Fulfillment Platform API Client library (Guzzle 7 fork)",
  "type": "library",
  "keywords": [
    "Api",
    "Http",
    "Client",
    "Linker Cloud Fulfillment Platform"
  ],
  "license": "MIT",
  "require": {
    "php": ">=8.1",
    "guzzlehttp/guzzle": "^7.0",
    "myclabs/php-enum": "^1.2",
    "doctrine/common": "^3.1",
    "jms/serializer": "^3.0"
  },
  "require-dev": {
    "phpunit/phpunit": "^10.0|^11.0"
  },
  "config": {
    "bin-dir": "bin"
  },
  "autoload": {
    "psr-4": {
      "": "src"
    }
  },
  "autoload-dev": {
    "psr-4": { "Linker\\Tests\\": "tests/" }
  }
}
